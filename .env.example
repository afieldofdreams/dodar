# ===========================================
# DODAR Framework — Environment Configuration
# ===========================================
# Copy this file to .env and fill in your API keys.
# At minimum, you need ONE provider key to run benchmarks.

# --- API Keys (at least one required) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...

# --- Model Overrides (optional) ---
# These override which model each provider uses for benchmark runs.
# Defaults shown below.
#
# Anthropic models: claude-opus-4-6, claude-sonnet-4-5, claude-haiku-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-5
#
# OpenAI models: gpt-5.4, gpt-4o, gpt-4o-mini, gpt-4.1-mini, gpt-4.1-nano
# OPENAI_MODEL=gpt-4o
#
# Google models: gemini-2.0-flash
# GOOGLE_MODEL=gemini-2.0-flash

# --- Auto-Scoring Model (optional) ---
# Which model evaluates responses during auto-scoring.
# Can be any Anthropic or OpenAI model.
# AUTOSCORE_MODEL=claude-opus-4-6

# --- Local Models (Ollama) ---
# No API key needed. Just have Ollama running on localhost:11434.
# Available: qwen2.5:14b, qwen2.5:7b, llama3.1:8b, phi3:3.8b
